# ====================================================
# Production run for DDL (GAFF/AM1-BCC) + TIP3P water
# NVT then optional NPT
# ====================================================

units real
boundary p p p
atom_style full

read_restart after_NPT_100ps.restart   # 使用平衡后的 NPT 重启文件
