pair_modify mix arithmetic
special_bonds lj 0.0 0.0 0.5 coul 0.0 0.0 0.8333

bond_style harmonic
angle_style harmonic
dihedral_style fourier
improper_style cvff

read_data system_DDL_TIP3P.data
